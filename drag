local function createInput(label, default, yPos)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0, 200, 0, 20)
    l.Position = UDim2.new(0, 10, 0, yPos)
    l.Text = label
    l.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    l.BackgroundTransparency = 1
    l.Parent = mainFrame
    
    local b = Instance.new("TextBox")
    b.Size = UDim2.new(0, 180, 0, 30)
    b.Position = UDim2.new(0, 10, 0, yPos + 20)
    b.Text = tostring(default)
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.ClearTextOnFocus = false -- ไม่ลบข้อความเวลาจะพิมพ์ใหม่
    b.Parent = mainFrame
    return b
end


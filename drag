-- Update logic
powerInput.FocusLost:Connect(function() nitroPower = tonumber(powerInput.Text) or 2 end)
speedInput.FocusLost:Connect(function() targetMaxSpeed = tonumber(speedInput.Text) or 280 end)

UIS.InputBegan:Connect(function(input, processed)
    if not scriptActive or not keyVerified or processed then return end
    if input.KeyCode == Enum.KeyCode.X then
        isBoosting = true
        statusLabel.Text = "⚡ BOOST ACTIVE "
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
        tweenService:Create(statusLabel, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 50, 20)}):Play()
    elseif input.KeyCode == Enum.KeyCode.M then
        mainFrame.Visible = not mainFrame.Visible
    elseif input.KeyCode == Enum.KeyCode.K then
        scriptActive = false
        screenGui:Destroy()
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.X then
        isBoosting = false
        statusLabel.Text = "กดบูสสสสสสส"
        statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        tweenService:Create(statusLabel, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
    end
end)

runService.Heartbeat:Connect(function()
    if not scriptActive or not isBoosting or not keyVerified then return end
    local char = player.Character
    local seat = char and char:FindFirstChild("Humanoid") and char.Humanoid.SeatPart
    
    if seat and seat:IsA("VehicleSeat") then
        local velocity = seat.AssemblyLinearVelocity
        local speed = (velocity * Vector3.new(1, 0, 1)).Magnitude 
        
        seat.MaxSpeed = targetMaxSpeed + 15
        
        if speed < targetMaxSpeed then
            local accelFactor = 0.22 
            seat:ApplyImpulse(seat.CFrame.LookVector * (seat.AssemblyMass * nitroPower * accelFactor))
            seat:ApplyImpulse(Vector3.new(0, -seat.AssemblyMass * 0.4, 0))
            seat.AssemblyAngularVelocity = seat.AssemblyAngularVelocity * 0.92
        end
    end
end)

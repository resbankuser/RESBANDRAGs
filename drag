local function createInputModern(label, default, yPos)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0, 210, 0, 20)
    l.Position = UDim2.new(0, 15, 0, yPos)
    l.Text = label:upper()
    l.TextColor3 = Color3.fromRGB(100, 100, 100)
    l.Font = Enum.Font.GothamBold
    l.TextSize = 10
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.BackgroundTransparency = 1
    l.Parent = mainFrame
    
    local b = Instance.new("TextBox")
    b.Size = UDim2.new(0, 210, 0, 35)
    b.Position = UDim2.new(0, 15, 0, yPos + 20)
    b.Text = tostring(default)
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamMedium
    b.Parent = mainFrame
    createCorner(b)
    return b
end


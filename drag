-- ฟังก์ชันดึงค่าจาก UI
powerInput.FocusLost:Connect(function() nitroPower = tonumber(powerInput.Text) or 3 end)
speedInput.FocusLost:Connect(function() targetMaxSpeed = tonumber(speedInput.Text) or 500 end)

UIS.InputBegan:Connect(function(input, processed)
    if not scriptActive or not keyVerified or processed then return end
    if input.KeyCode == Enum.KeyCode.X then
        autoMode = not autoMode
        statusLabel.Text = autoMode and "🚀 AUTO-PILOT: ON" or "🔘 AUTO-PILOT: OFF"
        statusLabel.TextColor3 = autoMode and Color3.new(0.3, 1, 0.3) or Color3.new(1, 0.3, 0.3)
    elseif input.KeyCode == Enum.KeyCode.M then
        mainFrame.Visible = not mainFrame.Visible
    elseif input.KeyCode == Enum.KeyCode.K then
        scriptActive = false
        screenGui:Destroy()
    end
end)

-- Physics
runService.Heartbeat:Connect(function()
    if not scriptActive or not autoMode or not keyVerified then return end
    local char = player.Character
    local seat = char and char:FindFirstChild("Humanoid") and char.Humanoid.SeatPart
    if seat and seat:IsA("VehicleSeat") then
        seat.MaxSpeed = targetMaxSpeed
        local velocity = seat.AssemblyLinearVelocity
        local speed = velocity.Magnitude
        if speed < targetMaxSpeed then
            seat:ApplyImpulse(seat.CFrame.LookVector * (seat.AssemblyMass * nitroPower * 0.45))
            local lookV = seat.CFrame.LookVector
            seat.AssemblyLinearVelocity = Vector3.new(lookV.X * speed, velocity.Y, lookV.Z * speed)
            seat:ApplyImpulse(Vector3.new(0, -speed * (seat.AssemblyMass / 40), 0))
            seat.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
    end
end)
